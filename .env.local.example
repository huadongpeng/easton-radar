# Copy this file to .env.local and fill local-only secrets.
# .env.local is ignored by git.

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Tavily is preferred for stable research search.
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_INCLUDE_RAW_CONTENT=false

# Brave Search is the fallback search provider.
BRAVE_SEARCH_API_KEY=

# Keep local runs bounded while testing.
SEARCH_API_CALL_LIMIT_PER_RUN=18

# Optional for local notification tests. Leave empty to skip with --no-telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
